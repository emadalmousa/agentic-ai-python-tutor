# OpenAI (optional) — wenn leer oder keine Credits → automatisch Ollama
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Ollama (Fallback, läuft lokal)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# RAG-Konfiguration (optional — Standardwerte werden verwendet wenn nicht gesetzt)
RAG_CHUNK_SIZE=500          # Anzahl Zeichen pro Text-Chunk
RAG_CHUNK_OVERLAP=50        # Überlappung zwischen benachbarten Chunks in Zeichen
RAG_TOP_K=3                 # Anzahl der zurückgegebenen relevantesten Chunks
RAG_VECTORSTORE_PATH=backend/agent/rag/vectorstore/  # Verzeichnis für den FAISS-Index
